from __future__ import annotations
from collections import Counter
from typing import Dict, List, Tuple

def train_bpe(input_path: str, vocab_size: int, special_tokens: List[str]) -> Tuple[Dict[int, bytes], List[Tuple[bytes, bytes]]]:
    """
    Train a byte-level BPE tokenizer.

    Returns:
        vocab: dict[int, bytes]  (token_id -> token_bytes)
        merges: list[tuple[bytes, bytes]]  ordered by creation
    """
    # Make sure vocab_size is valid
    if not isinstance(vocab_size, int) or vocab_size <= 0:
        raise ValueError("vocab_size must be a positive integer")

    # Start vocab with all single bytes (0..255)
    vocab: Dict[int, bytes] = {i: bytes([i]) for i in range(256)}
    next_id = 256  # next new token id we will assign

    # Read the training file as raw bytes (not as text)
    with open(input_path, "rb") as f:
        data = f.read()

    # Start token sequence as byte values (each byte is its own token ID initially)
    seq: List[int] = list(data)

    # Store merge rules in the order we create them
    merges: List[Tuple[bytes, bytes]] = []

    # Add special tokens to vocab, but do NOT train merges using them
    # (because they never appear inside seq)
    for tok in special_tokens:
        b = tok.encode("utf-8")
        vocab[next_id] = b
        next_id += 1

    # If vocab_size is too small, we can't do any merges
    if vocab_size <= len(vocab):
        return vocab, merges

    # We keep merging until vocab reaches this size
    target_vocab_size = vocab_size

    # Pick the best pair to merge:
    # 1) highest frequency
    # 2) if tie, pick the lexicographically smallest pair (based on bytes) for stability
    def best_pair(pair_counts: Counter[Tuple[int, int]]) -> Tuple[int, int] | None:
        if not pair_counts:
            return None
        best_freq = max(pair_counts.values())
        candidates = [p for p, c in pair_counts.items() if c == best_freq]
        candidates.sort(key=lambda p: (vocab[p[0]], vocab[p[1]]))
        return candidates[0]

    # Keep creating new merged tokens until we hit target vocab size
    while len(vocab) < target_vocab_size:
        # Count how often each adjacent pair (token_i, token_{i+1}) appears
        pair_counts: Counter[Tuple[int, int]] = Counter()

        # If sequence is too short, we cannot form pairs
        if len(seq) < 2:
            break

        # Count pairs in one left-to-right pass
        prev = seq[0]
        for cur in seq[1:]:
            pair_counts[(prev, cur)] += 1
            prev = cur

        # Choose the best pair to merge
        pair = best_pair(pair_counts)
        if pair is None:
            break

        a_id, b_id = pair
        a_bytes, b_bytes = vocab[a_id], vocab[b_id]

        # Create the new merged token in vocab
        merged_bytes = a_bytes + b_bytes
        merged_id = next_id
        next_id += 1
        vocab[merged_id] = merged_bytes

        # Record the merge rule as bytes (not ids)
        merges.append((a_bytes, b_bytes))

        # Apply the merge everywhere in the token sequence (left-to-right)
        new_seq: List[int] = []
        i = 0
        n = len(seq)
        while i < n:
            # If we see the pair, replace it with the merged token
            if i < n - 1 and seq[i] == a_id and seq[i + 1] == b_id:
                new_seq.append(merged_id)
                i += 2
            else:
                # Otherwise keep the token
                new_seq.append(seq[i])
                i += 1

        # Update sequence for the next round
        seq = new_seq

    return vocab, merges