from __future__ import annotations

import torch


def _softmax_stable(logits: torch.Tensor, dim: int = -1) -> torch.Tensor:
    """
    Numerically stable softmax:
      softmax(x) = exp(x - max(x)) / sum(exp(x - max(x)))
    """
    x = logits - logits.max(dim=dim, keepdim=True).values
    exp_x = torch.exp(x)
    return exp_x / exp_x.sum(dim=dim, keepdim=True)


@torch.no_grad()
def decode(
    model,
    tokenizer,
    prompt: str,
    device: str,
    max_new_tokens: int = 100,
    temperature: float = 1.0,
    top_p: float = 1.0,
    eos_token_id: int | None = None,
) -> str:
    """
    Generate text from a language model using temperature + top-p sampling.
    """
    model.eval()
    device_t = torch.device(device)

    # Encode prompt into token IDs and add batch dimension -> (1, T)
    input_ids = torch.tensor(
        tokenizer.encode(prompt),
        dtype=torch.long,
        device=device_t,
    ).unsqueeze(0)

    for _ in range(max_new_tokens):
        # Model outputs logits for each position -> (1, T, V)
        logits = model(input_ids)

        # Only use the logits for the next token (last position) -> (1, V)
        next_logits = logits[:, -1, :]

        # Temperature scaling (higher = more random, lower = more deterministic)
        if temperature != 1.0:
            next_logits = next_logits / temperature

        # Convert logits -> probabilities (WITHOUT torch.nn.functional)
        probs = _softmax_stable(next_logits, dim=-1)  # (1, V)

        # Top-p (nucleus) sampling
        if top_p < 1.0:
            sorted_probs, sorted_indices = torch.sort(probs, descending=True)
            cumulative_probs = torch.cumsum(sorted_probs, dim=-1)

            # Keep the smallest set of tokens whose cumulative prob <= top_p
            cutoff = cumulative_probs > top_p
            cutoff[..., 1:] = cutoff[..., :-1].clone()
            cutoff[..., 0] = False

            sorted_probs = sorted_probs.clone()
            sorted_probs[cutoff] = 0.0

            # Re-normalize so probs sum to 1 again
            sorted_probs = sorted_probs / sorted_probs.sum(dim=-1, keepdim=True)

            # Sample from the filtered distribution, then map back to vocab ids
            sampled_in_sorted = torch.multinomial(sorted_probs, num_samples=1)  # (1, 1)
            next_token = sorted_indices.gather(-1, sampled_in_sorted)           # (1, 1)
        else:
            # Sample from full distribution
            next_token = torch.multinomial(probs, num_samples=1)  # (1, 1)

        # Append new token to the sequence
        input_ids = torch.cat([input_ids, next_token], dim=1)

        # Stop if we hit end-of-sequence
        if eos_token_id is not None and next_token.item() == eos_token_id:
            break

    # Decode all tokens back into text
    return tokenizer.decode(input_ids[0].tolist())